# ─── Application ──────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codebase_learning
DATABASE_URL_DOCKER=postgresql://postgres:postgres@postgres:5432/codebase_learning

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_URL_DOCKER=redis://redis:6379

# ─── Vector Database ───────────────────────────────────────────────────────
VECTOR_DB_URL=postgresql://postgres:postgres@localhost:5432/codebase_learning
VECTOR_DB_URL_DOCKER=postgresql://postgres:postgres@postgres:5432/codebase_learning

# ─── GitHub Integration ────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ─── LLM Provider ──────────────────────────────────────────────────────────
# Options: anthropic, openai
LLM_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Embedding Provider ────────────────────────────────────────────────────
# Options: openai, anthropic, local
EMBEDDING_PROVIDER=openai

# ─── Encryption ────────────────────────────────────────────────────────────
# 32-byte hex key for encrypting tokens at rest
ENCRYPTION_KEY=

# ─── NextAuth ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ─── Storage ───────────────────────────────────────────────────────────────
SNAPSHOT_DIR=./snapshots

# ─── Celery / Worker ───────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_BROKER_URL_DOCKER=redis://redis:6379/1

# ─── Observability ─────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# ─── Feature Flags ─────────────────────────────────────────────────────────
ENABLE_GITHUB_AUTH=true
ENABLE_PUBLIC_IMPORT=true
ENABLE_TEAM_SPACES=false
ENABLE_EPHEMERAL_MODE=false
MAX_FILE_SIZE_BYTES=1000000
MAX_FILES_PER_REPO=10000
